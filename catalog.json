{
  "schema_version": "1.0",
  "project": "ai-ephemeris-data",
  "purpose": "AI-readable static ephemeris dataset catalog",
  "lookup_rule": "Read this catalog first, choose the dataset covering the requested UTC date and cadence, then read that dataset index and one daily JSONL/GZIP file.",
  "datasets": [
    {
      "id": "examples-main",
      "status": "examples",
      "description": "Small default-branch example dataset. Full generated ranges are listed as separate catalog entries when available.",
      "repository": "https://github.com/ephemeris-ai/ai-ephemeris-data",
      "index_url": "https://raw.githubusercontent.com/ephemeris-ai/ai-ephemeris-data/main/index.json",
      "pages_index_url": "https://ephemeris-ai.github.io/ai-ephemeris-data/index.json",
      "base_url": "https://raw.githubusercontent.com/ephemeris-ai/ai-ephemeris-data/main/",
      "date_range": {
        "start": "2026-01-01",
        "end": "2026-01-01"
      },
      "cadences": [
        {
          "cadence": "10min",
          "date_range": {
            "start": "2026-01-01",
            "end": "2026-01-01"
          },
          "recommended_use": "single-day example file"
        },
        {
          "cadence": "60min",
          "date_range": {
            "start": "2026-01-01",
            "end": "2026-01-01"
          },
          "recommended_use": "single-day compact example file"
        }
      ]
    }
  ],
  "large_dataset_policy": "Full historical ranges should be published outside the default branch, for example in data-only repositories, releases, or static object storage."
}
